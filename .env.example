# Backend API URL (required - e.g. https://your-app.up.railway.app)
VITE_API_URL=

# Firebase (for client auth - optional if using backend-only auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Action URL for Firebase email link / password reset (e.g. https://your-app.vercel.app/login)
VITE_AUTH_ACTION_URL=
