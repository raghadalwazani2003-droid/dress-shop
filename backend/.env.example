# Server
PORT=5000
NODE_ENV=production

# Auth (JWT)
JWT_SECRET=
JWT_EXPIRY=30d

# CORS - comma-separated frontend URLs (required in production)
FRONTEND_URL=
# Alternative name:
# CLIENT_URL=

# Email (for OTP and forgot password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MOTEX <noreply@example.com>

# Firebase (optional - for Firebase Admin SDK)
# On Railway: paste JSON content as FIREBASE_SERVICE_ACCOUNT
# Locally: use firebase-service-account.json file
# FIREBASE_SERVICE_ACCOUNT=
